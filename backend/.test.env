ADMIN_USERNAME=admin
ADMIN_PASSWORD=password

# Used by root docker-compose.yml for the life-manager service env_file path.
ENV_FILE=backend/.test.env

# docker-compose.yml image: lines when using prod/tesseract profiles with this env file.
LIFE_MANAGER_BACKEND_IMAGE=089366939950.dkr.ecr.us-west-2.amazonaws.com/life-manager-backend:latest
LIFE_MANAGER_FRONTEND_IMAGE=089366939950.dkr.ecr.us-west-2.amazonaws.com/life-manager-frontend:latest
LIFE_MANAGER_GATEWAY_IMAGE=089366939950.dkr.ecr.us-west-2.amazonaws.com/life-manager-gateway:latest
TESSERACT_SERVER_IMAGE=hertzg/tesseract-server:latest

APP_PORT=3000
OLLAMA_PORT=11434
TESSERACT_PORT=8884
FRONTEND_PORT=8080

DATABASE_URL=./data/test.db
TESSERACT_ENABLED=false
TESSERACT_URL=http://localhost:${TESSERACT_PORT}
OLLAMA_URL=http://localhost:${OLLAMA_PORT}
RUST_LOG=debug

JWT_SECRET=test-secret
RUST_BACKTRACE=1
